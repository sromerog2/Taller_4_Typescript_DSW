{
  "compilerOptions": {
    /* Lenguaje */
    "target": "es2020",

    /* Módulos (CLAVE para evitar tu error) */
    "module": "Node16",
    "moduleResolution": "node16",
    "verbatimModuleSyntax": false,

    /* Estructura del proyecto */
    "rootDir": "./src",
    "outDir": "./src",

    /* Tipado y seguridad */
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    /* Calidad de vida */
    "skipLibCheck": true
  },

  "include": ["src/**/*"]
}
